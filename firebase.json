{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase-debug.log",
      "firebase-service-account.json",
      "firebase.json",
      ".firebaserc",
      "functions/**",
      "node_modules/**",
      "**/.*"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": {
          "functionId": "api",
          "region": "europe-west6"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
