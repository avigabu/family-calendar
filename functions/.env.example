# Google OAuth Client Credentials
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# AES-256-CBC Encryption Key (Must be exactly 32 characters/bytes)
# You can generate a random 32-character string to encrypt credentials securely.
ENCRYPTION_KEY=some_random_secret_key_32_bytes_
